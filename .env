    # PostgreSQL
    POSTGRES_HOST=localhost
    POSTGRES_PORT=5432
    POSTGRES_DB=postgres
    POSTGRES_USER=postgres
    POSTGRES_PASSWORD=xxxxx

    # RabbitMQ
    RABBITMQ_HOST=localhost
    RABBITMQ_PORT=5672
    RABBITMQ_USER=guest
    RABBITMQ_PASSWORD=guest
    RABBITMQ_QUEUE=telemetry

    # Ollama
    OLLAMA_HOST=http://localhost:11434
    OLLAMA_MODEL=llama3

    # ML Settings
    ANOMALY_THRESHOLD=0.05
    DEGRADATION_THRESHOLD=0.08
    CONTAMINATION=0.01

    # Application
    LOG_LEVEL=INFO
    BATCH_SIZE=60

    # PostgreSQL DB for MLflow backend store (used by run_all.ps1 and main.py to launch MLflow server)
    POSTGRES_MLFLOW_HOST=localhost
    POSTGRES_MLFLOW_PORT=5432
    POSTGRES_MLFLOW_DB=mlflow
    POSTGRES_MLFLOW_USER=postgres
    POSTGRES_MLFLOW_PASSWORD=xxxx
